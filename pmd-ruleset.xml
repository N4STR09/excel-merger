<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="excel-merger-pmd"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        Ruleset PMD de Excel Merger (Sesión E, Fase 3; revisado en v2.0.1).

        NOTA HISTÓRICA: El brief original pedía los rulesets clásicos
        "java-basic", "java-design", "java-unusedcode". Estos nombres
        fueron eliminados en PMD 6.0.0 (2017) y reorganizados en
        categorías. Este ruleset usa los sustitutos equivalentes:

          java-basic     ->  category/java/errorprone.xml
                              + partes de category/java/bestpractices.xml
          java-unusedcode-> category/java/bestpractices.xml
                              (UnusedLocalVariable, UnusedPrivateField, ...)
          java-design    ->  category/java/design.xml

        v2.0.1: segunda vuelta de limpieza. Se atacaron las exclusiones
        anotadas como "para segunda pasada" en v2.0.0. Ver CHANGELOG.

        Para tests se aplica un subset más laxo (ver elemento exclude-pattern).
    </description>

    <!-- Tests: PMD solo analiza src/main/java. La exclusión src/test/java
         se hace también vía maven-pmd-plugin (includeTests=false). -->
    <exclude-pattern>.*/src/test/.*</exclude-pattern>

    <!-- === ERROR PRONE =========================================== -->
    <rule ref="category/java/errorprone.xml">
        <!-- Conflictos con loggers SLF4J y patrones de try-with-resources
             habituales. Se excluyen reglas que se sabe producen falsos
             positivos en este dominio. -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="BeanMembersShouldSerialize"/>
        <exclude name="DataflowAnomalyAnalysis"/>
        <exclude name="NullAssignment"/>
        <!-- POI a veces requiere catch-and-log; la regla es demasiado estricta -->
        <exclude name="AvoidCatchingGenericException"/>

        <!-- v2.0.1: AvoidDuplicateLiterals se REACTIVA con minimumLength=5
             (ver configuración de la regla más abajo). Los literales
             de dominio se extrajeron a constantes. -->

        <!-- v2.0.1: UseLocaleWithCaseConversions y AssignmentInOperand
             se REACTIVAN; los 20 + 5 casos se arreglaron en código. -->

        <!-- Falso positivo: advierte sobre ClassLoader en contexto J2EE;
             excel-merger es una CLI standalone, no aplica. -->
        <exclude name="UseProperClassLoader"/>

        <!-- Falso positivo: Main.readGitProperties() devuelve Properties
             (no una Collection); PMD confunde tipos. -->
        <exclude name="ReturnEmptyCollectionRatherThanNull"/>
    </rule>

    <!-- Configuración específica de AvoidDuplicateLiterals.
         v2.0.1: minimumLength=5 filtra literales muy cortos que son
         ruido de concatenación ("').", ",\"", "SUM(") y no añaden
         valor al extraerse. Los 7 literales de dominio duplicados
         (CABECERA, CONFIG, LOOKUP, Calibri, mes.col., separador de
         banner, y 5 fragmentos de mensajes de error) se extrajeron
         a constantes en su clase respectiva. -->
    <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals">
        <properties>
            <property name="minimumLength" value="5"/>
            <property name="maxDuplicateLiterals" value="4"/>
            <property name="skipAnnotations" value="true"/>
        </properties>
    </rule>

    <!-- === BEST PRACTICES ======================================== -->
    <rule ref="category/java/bestpractices.xml">
        <!-- Reglas ruidosas en código con muchos constants y logs -->
        <exclude name="GuardLogStatement"/>
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <exclude name="JUnitTestContainsTooManyAsserts"/>
        <exclude name="JUnitTestsShouldIncludeAssert"/>
        <exclude name="LooseCoupling"/>
        <!-- En tests se permite acceso a miembros no-públicos -->
        <exclude name="AccessorMethodGeneration"/>

        <!-- === Exclusiones tras primera corrida real de PMD === -->

        <!-- 21 ocurrencias. Main.java es una CLI; System.out.println es
             exactamente el canal correcto para las flags help y version.
             Usar SLF4J para stdout sería peor. -->
        <exclude name="SystemPrintln"/>

        <!-- DerivedSheetBuilder.buildFormula: switch exhaustivo con default.
             Estilo moderno Java 21+ permite omitir default; PMD se queja
             pero no es bug. -->
        <exclude name="ExhaustiveSwitchHasDefault"/>
    </rule>

    <!-- === DESIGN (equivalente a java-design) ==================== -->
    <rule ref="category/java/design.xml">
        <!-- DECISIÓN ARQUITECTÓNICA (v2.0.1, revisada en v2.5.0): los
             orquestadores MesSheetBuilder (772 LoC) y SummarySheetBuilder
             (664 LoC) son legítimamente complejos porque cada uno encapsula
             una transformación Excel completa con múltiples casos de
             negocio. Partirlos en colaboradores pequeños fragmentaría la
             lógica de dominio sin ganancia real de mantenibilidad: cada
             sub-pieza solo tendría sentido en el contexto del orquestador.

             v2.5.0 (Sesión F, parte 1): ConfigValidator SÍ se partió en
             un orquestador delgado (~80 LoC) más siete *ConfigSection
             colaboradoras en el subpaquete com.excelmerger.config. El
             refactor fue posible porque las validaciones del config
             tienen baja cohesión (cada bloque de validación es
             independiente y solo comparte la lista 'errors' acumulada),
             cosa que NO ocurre en MesSheetBuilder ni SummarySheetBuilder.
             Las exclusiones siguen escritas a nivel de ruleset (no por
             fichero) porque PMD no soporta de forma estándar excludes
             por path en este proyecto, y porque las dos clases que
             quedan justifican la exclusión global. Una futura Sesión F2
             que aborde MesSheetBuilder o SummarySheetBuilder podrá
             reevaluarlas.

             En v2.0.1 se revisó caso por caso:
             - Las exclusiones que sí cubrían código real pero eran
               fáciles de arreglar sin cambio arquitectónico se
               arreglaron y se retiraron del exclude list (ver errorprone
               arriba).
             - Las exclusiones que resultaron tener 0 violaciones reales
               hoy (AvoidThrowingRawExceptionTypes, SignatureDeclareThrowsException,
               UseUtilityClass, LoosePackageCoupling) se retiraron.
             - El resto, que afecta a los orquestadores grandes, se queda
               excluido conscientemente con la justificación de abajo. -->

        <!-- POI requiere catch-and-log defensivo: evaluateAll(),
             autoSizeColumn() y rutinas similares pueden lanzar varias
             subclases de RuntimeException no declaradas (POI no las
             documenta consistentemente). Capturar Exception es la única
             forma práctica de evitar que un bug de POI tumbe el merger.
             Los 5 catches en DerivedSheetBuilder (2), FileProfileResolver
             (1), Main (1) y un catch-ignored en autoSizeColumn son todos
             conscientes. La exclusión efectiva vive en el bloque
             errorprone de arriba; desde PMD 7.18.0 la regla se movió
             de design a errorprone (PMD 8 retirará la ubicación antigua). -->

        <!-- Complejidad ciclomática / cognitiva / NPath / Ncss:
             MesSheetBuilder y SummarySheetBuilder concentran mucha lógica
             de construcción de hojas Excel que no se puede descomponer
             sin perder cohesión. Ver nota arquitectónica arriba. -->
        <exclude name="CognitiveComplexity"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="NcssCount"/>

        <!-- Acoplamiento a POI es inevitable por diseño. -->
        <exclude name="CouplingBetweenObjects"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="ExcessiveParameterList"/>
        <exclude name="ExcessivePublicCount"/>

        <!-- Tamaño de orquestadores: ver nota arquitectónica arriba. -->
        <exclude name="GodClass"/>
        <exclude name="TooManyFields"/>
        <exclude name="TooManyMethods"/>

        <!-- DataClass: RunReport y VlookupLink son objetos de valor
             intencionales; DataClass es la forma correcta para ellos. -->
        <exclude name="DataClass"/>

        <!-- POI requiere cadenas como row.getCell(i).getStringCellValue().
             LawOfDemeter no se puede respetar sin envolver POI completamente. -->
        <exclude name="LawOfDemeter"/>
    </rule>

</ruleset>
